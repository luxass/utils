{
  "name": "@luxass/utils",
  "version": "2.7.5",
  "description": "A collection of utilities for JavaScript/TypeScript",
  "keywords": [
    "utils"
  ],
  "homepage": "https://github.com/luxass/utils",
  "bugs": {
    "url": "https://github.com/luxass/utils/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Lucas Nørgård",
    "email": "lucasnrgaard@gmail.com",
    "url": "https://luxass.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luxass/utils.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./guards": "./dist/guards.mjs",
    "./number": "./dist/number.mjs",
    "./object": "./dist/object.mjs",
    "./path": "./dist/path.mjs",
    "./string": "./dist/string.mjs",
    "./types": "./dist/types.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest --run",
    "test:watch": "vitest",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "p-retry": "catalog:prod"
  },
  "devDependencies": {
    "@types/node": "catalog:dev",
    "oxfmt": "catalog:dev",
    "oxlint": "catalog:dev",
    "oxlint-tsgolint": "catalog:dev",
    "publint": "catalog:dev",
    "tsdown": "catalog:dev",
    "tsnapi": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "catalog:dev"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.8.0"
}
